<Window x:Class="MHWStatOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CasualHunter"
        Width="500" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="#FF1A1A28" Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="TitleText" Foreground="#FFD4A838" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0"
                             Fill="{Binding ConnectionBrush}"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="#CCCCCC" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Bottom buttons -->
        <Border DockPanel.Dock="Bottom" Padding="12,8" Background="#FFF0F0F0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnReset" Command="{Binding SettingsVM.ResetCommand}" Width="80" Margin="0,0,8,0"/>
                <Button x:Name="BtnSave" Command="{Binding SettingsVM.SaveCommand}" Width="80"/>
            </StackPanel>
        </Border>

        <!-- Settings tabs -->
        <TabControl Margin="8">
            <TabItem x:Name="TabGeneral">
                <StackPanel Margin="8">
                    <GroupBox x:Name="GrpGeneral">
                        <StackPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblPolling" Width="130"/>
                                <TextBox Text="{Binding SettingsVM.PollingRateMs, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblOpacity" Width="130"/>
                                <Slider Value="{Binding SettingsVM.GlobalOpacity}" Minimum="0.1" Maximum="1.0"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True" Width="200"/>
                                <TextBlock Text="{Binding SettingsVM.GlobalOpacity, StringFormat={}{0:P0}}" Margin="8,0,0,0"/>
                            </DockPanel>
                            <CheckBox x:Name="ChkLocked" IsChecked="{Binding SettingsVM.OverlayLocked}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabMonster">
                <StackPanel Margin="8">
                    <GroupBox x:Name="GrpMonster">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowMonster" IsChecked="{Binding SettingsVM.ShowMonsterWidget}"/>
                            <CheckBox x:Name="ChkShowHP" IsChecked="{Binding SettingsVM.ShowMonsterHP}"/>
                            <CheckBox x:Name="ChkShowHPValues" IsChecked="{Binding SettingsVM.ShowMonsterHPValues}"/>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblMonsterWidth" Width="130"/>
                                <Slider Value="{Binding SettingsVM.MonsterWidgetWidth}" Minimum="150" Maximum="600" Width="200"/>
                                <TextBlock Text="{Binding SettingsVM.MonsterWidgetWidth, StringFormat={}{0:F0}}" Margin="8,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="GrpPart">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowPart" IsChecked="{Binding SettingsVM.ShowPartWidget}"/>
                            <CheckBox x:Name="ChkShowBreak" IsChecked="{Binding SettingsVM.ShowPartBreakCount}"/>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblPartWidth" Width="130"/>
                                <Slider Value="{Binding SettingsVM.PartWidgetWidth}" Minimum="150" Maximum="500" Width="200"/>
                                <TextBlock Text="{Binding SettingsVM.PartWidgetWidth, StringFormat={}{0:F0}}" Margin="8,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabDamage">
                <StackPanel Margin="8">
                    <GroupBox x:Name="GrpDamage">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowDamage" IsChecked="{Binding SettingsVM.ShowDamageWidget}"/>
                            <CheckBox x:Name="ChkShowDmgNumbers" IsChecked="{Binding SettingsVM.ShowDamageNumbers}"/>
                            <CheckBox x:Name="ChkShowPct" IsChecked="{Binding SettingsVM.ShowDamagePercentage}"/>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblDamageWidth" Width="130"/>
                                <Slider Value="{Binding SettingsVM.DamageWidgetWidth}" Minimum="150" Maximum="500" Width="200"/>
                                <TextBlock Text="{Binding SettingsVM.DamageWidgetWidth, StringFormat={}{0:F0}}" Margin="8,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabQuest">
                <StackPanel Margin="8">
                    <GroupBox x:Name="GrpQuest">
                        <StackPanel>
                            <CheckBox x:Name="ChkShowQuest" IsChecked="{Binding SettingsVM.ShowQuestWidget}"/>
                            <DockPanel Margin="0,4">
                                <TextBlock x:Name="LblQuestWidth" Width="130"/>
                                <Slider Value="{Binding SettingsVM.QuestWidgetWidth}" Minimum="150" Maximum="500" Width="200"/>
                                <TextBlock Text="{Binding SettingsVM.QuestWidgetWidth, StringFormat={}{0:F0}}" Margin="8,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

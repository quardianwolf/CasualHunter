<UserControl x:Class="MHWStatOverlay.Views.Widgets.QuestWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Visibility="{Binding Quest.IsActive, Converter={StaticResource BoolToVisibility}}">
        <DockPanel>
            <TextBlock Text="{Binding Quest.Name}" Foreground="#CCE8E4DC" FontSize="12"
                       FontWeight="SemiBold" FontFamily="Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Color="#000000" Opacity="0.9"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Faint counter -->
                <TextBlock FontSize="11" FontFamily="Segoe UI" FontWeight="Bold"
                           Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="#000000" Opacity="0.9"/>
                    </TextBlock.Effect>
                    <Run Text="&#x2764;" Foreground="#90C83020"/>
                    <Run Text="{Binding Quest.RemainingFaints, Mode=OneWay}" Foreground="#AAC8B888"/>
                </TextBlock>

                <TextBlock Text="{Binding Quest.TimerFormatted}"
                           Foreground="#FFD4A838" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="#000000" Opacity="0.9"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</UserControl>

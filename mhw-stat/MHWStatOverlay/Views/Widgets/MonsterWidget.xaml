<UserControl x:Class="MHWStatOverlay.Views.Widgets.MonsterWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ItemsControl ItemsSource="{Binding Monsters}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <StackPanel Margin="0,0,0,10">
                    <!-- Name row -->
                    <Grid Margin="0,0,0,3">
                        <TextBlock Text="{Binding Name}" Foreground="#DDE0D8C8"
                                   FontSize="14" FontFamily="Segoe UI" FontWeight="Bold">
                            <TextBlock.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="8" Color="#000000" Opacity="0.95"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Visibility="{Binding IsEnraged, Converter={StaticResource BoolToVisibility}}"
                                       FontSize="11" FontFamily="Segoe UI" FontWeight="Bold"
                                       Foreground="#FFE83820" Margin="0,0,12,0" VerticalAlignment="Bottom">
                                <TextBlock.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="10" Color="#E83820" Opacity="0.8"/>
                                </TextBlock.Effect>
                                <Run Text="RAGE "/>
                                <Run Text="{Binding RageTimer, StringFormat={}{0:F0}s, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock Text="{Binding HPPercentage, StringFormat={}{0:F1}%}"
                                       Foreground="#CCC8A868" FontSize="13" FontFamily="Segoe UI"
                                       FontWeight="Bold" VerticalAlignment="Bottom">
                                <TextBlock.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="5" Color="#000000" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Gradient stage behind bar -->
                    <Grid>
                        <Border Height="20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#70080808" Offset="0"/>
                                    <GradientStop Color="#50050505" Offset="0.5"/>
                                    <GradientStop Color="#20000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Bar container -->
                        <Grid Height="8" Margin="0,3,0,0" VerticalAlignment="Top">
                            <!-- Track -->
                            <Grid>
                                <Border Background="#50201810" Margin="4,0,4,0"/>
                                <!-- Left point -->
                                <Polygon Points="0,4 4,0 4,8" Fill="#50201810"
                                         HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <!-- Right point -->
                                <Polygon Points="4,4 0,0 0,8" Fill="#50201810"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- HP Fill -->
                            <Border HorizontalAlignment="Left" Margin="4,0,4,0">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="HPPercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF4f1119" Offset="0"/>
                                        <GradientStop Color="#FF2a0a0e" Offset="0.6"/>
                                        <GradientStop Color="#FF1a0508" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="#4f1119" Opacity="0.4"/>
                                </Border.Effect>
                            </Border>

                            <!-- Top highlight on fill -->
                            <Border HorizontalAlignment="Left" Height="2" VerticalAlignment="Top"
                                    Margin="4,0,4,0" IsHitTestVisible="False" Opacity="0.25"
                                    Background="White">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="HPPercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>

                            <!-- Bottom bright edge -->
                            <Border Height="1" VerticalAlignment="Bottom" Margin="4,0,4,0"
                                    Background="#20FFFFFF"/>
                        </Grid>
                    </Grid>

                    <!-- HP values -->
                    <TextBlock Margin="4,1,0,0" FontFamily="Segoe UI" FontSize="9"
                               Visibility="{Binding DataContext.Settings.ShowMonsterHPValues,
                               RelativeSource={RelativeSource AncestorType=ItemsControl},
                               Converter={StaticResource BoolToVisibility}}">
                        <TextBlock.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="#000000" Opacity="0.85"/>
                        </TextBlock.Effect>
                        <Run Text="{Binding CurrentHP, StringFormat={}{0:N0}, Mode=OneWay}" Foreground="#70C8B888"/>
                        <Run Text=" / " Foreground="#30C8B888"/>
                        <Run Text="{Binding MaxHP, StringFormat={}{0:N0}, Mode=OneWay}" Foreground="#40C8B888"/>
                    </TextBlock>

                    <!-- Status effects row -->
                    <ItemsControl ItemsSource="{Binding StatusEffects}" Margin="4,3,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,8,0"
                                            Visibility="{Binding HasBuildup, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding Icon}" FontSize="9" Margin="0,0,2,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="#000000" Opacity="0.9"/>
                                        </TextBlock.Effect>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#80C8A868"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFE85028"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding BuildupPercentage, StringFormat={}{0:F0}%}"
                                               FontSize="9" FontFamily="Segoe UI"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="#000000" Opacity="0.9"/>
                                        </TextBlock.Effect>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#60C8B888"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#CCE85028"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Alatreon Elemental Threshold -->
                    <StackPanel Visibility="{Binding IsAlatreon, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,5,0,0">
                        <!-- Label row -->
                        <DockPanel Margin="4,0,4,1">
                            <TextBlock FontSize="10" FontFamily="Segoe UI" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Color="#000000" Opacity="0.9"/>
                                </TextBlock.Effect>
                                <Run Text="&#x2726; ELEMENT" Foreground="#CC38A8D8"/>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock FontSize="9" FontFamily="Segoe UI" Foreground="#8038A8D8"
                                           Margin="0,0,8,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="#000000" Opacity="0.9"/>
                                    </TextBlock.Effect>
                                    <Run Text="{Binding AlatreonElementRemaining, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock FontSize="10" FontFamily="Segoe UI" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="#000000" Opacity="0.9"/>
                                    </TextBlock.Effect>
                                    <Run Text="x" Foreground="#5038A8D8"/>
                                    <Run Text="{Binding AlatreonToppleCount, Mode=OneWay}" Foreground="#CC38A8D8"/>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>

                        <!-- Element threshold bar — uses percentage -->
                        <Grid Height="6">
                            <Grid>
                                <Border Background="#40181520" Margin="3,0,3,0"/>
                                <Polygon Points="0,3 3,0 3,6" Fill="#40181520"
                                         HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <Polygon Points="3,3 0,0 0,6" Fill="#40181520"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <Border HorizontalAlignment="Left" Margin="3,0,3,0">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="AlatreonElementPercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#DD28A0D8" Offset="0"/>
                                        <GradientStop Color="#DD105880" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="#28A0D8" Opacity="0.5"/>
                                </Border.Effect>
                            </Border>

                            <Border Height="1" VerticalAlignment="Top" Margin="3,0,3,0"
                                    IsHitTestVisible="False" Opacity="0.2" Background="White">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                        <Binding Path="AlatreonElementPercentage"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>

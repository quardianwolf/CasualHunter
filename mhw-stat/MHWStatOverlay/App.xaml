<Application x:Class="MHWStatOverlay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MHWStatOverlay.Helpers"
             Startup="App_OnStartup"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
    </Application.Resources>
</Application>
